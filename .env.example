# ─────────────────────────────────────────────
#  Bot Panel — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Admin credentials (used for panel login)
ADMIN_USERNAME=admin
# Generate hash: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',10))"
ADMIN_PASSWORD_HASH=$2a$10$examplehashedpasswordhere

# JWT secret — generate a strong random string
JWT_SECRET=changeme_very_long_random_secret_here

# External API Auth (for ArnTo-Auto Discord Bot)
PANEL_API_KEY=your_secure_secret_key

# Absolute path to the bots root folder
# e.g., /root/bots
BOTS_ROOT_DIR=/root/bots

# ── Discord — Admin/Alert Notifications ──────
# Webhook for expiry warnings and removal alerts
DISCORD_ALERT_WEBHOOK=https://discord.com/api/webhooks/xxx/yyy

# Webhook for hourly DB backups
DISCORD_BACKUP_WEBHOOK=https://discord.com/api/webhooks/xxx/yyy

# ── Discord — Buyer Bot ───────────────────────
# Bot token for the buyer-facing Discord bot
BUYER_BOT_TOKEN=your_buyer_bot_token_here

# ── Panel PM2 Name (optional — auto-detected when running under PM2) ──
# Only needed if auto-detection fails
PANEL_PM2_NAME=bot-panel

# ── Client (only needed in development) ──────
CLIENT_URL=http://localhost:5173
