# Port the agent listens on — must match the node's port registered in the panel
AGENT_PORT=4200

# Shared secret — the panel sends this in the "x-agent-key" header.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AGENT_API_KEY=

# Where bot folders live on THIS VPS (created by setup-agent.sh)
BOTS_ROOT_DIR=/root/bots

# Where website folders live (defaults to BOTS_ROOT_DIR if unset)
SITES_ROOT_DIR=/root/sites
